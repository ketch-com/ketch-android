<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KetchSample" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ketch_purple</item>
        <item name="colorPrimaryDark">@color/ketch_purple_dark</item>
        <item name="colorAccent">@color/ketch_purple</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Widget.KetchSample.Button.Execute" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/ketch_purple</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
    </style>
</resources>
